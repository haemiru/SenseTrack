# --- Supabase (브라우저에서 사용 — 공개되는 anon key) ---
# 기존 jjangasem-bookshop 프로젝트의 값을 사용합니다.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key_here"

# --- 책방 로그인 (네이버 등 Supabase 미지원 로그인을 위임할 책방 로그인 페이지) ---
# 미설정 시 https://jjangsaem.com/ko/auth 기본값 사용. ?redirect=<센스트랙주소>가 붙어 호출됩니다.
VITE_BOOKSHOP_LOGIN_URL="https://jjangsaem.com/ko/auth"

# --- Anthropic (서버 사이드 전용 — Vercel 환경변수에 설정, 절대 VITE_ 접두어 금지) ---
# 로컬에서 `vercel dev`로 /api 함수를 테스트할 때만 .env에 두면 됩니다.
ANTHROPIC_API_KEY="sk-ant-..."
